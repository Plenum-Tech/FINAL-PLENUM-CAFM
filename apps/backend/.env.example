# Root-level .env.example — Template for environment variables
# Copy this to .env and fill in your actual values
# DO NOT commit .env to GitHub (it's in .gitignore)

# ── Claude API (Anthropic) ──────────────────────────────────────────────
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI (Embeddings) ─────────────────────────────────────────────────
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LangSmith (Observability) ───────────────────────────────────────────
# Get from: https://smith.langchain.com/settings
LANGSMITH_API_KEY=lsv2_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database ────────────────────────────────────────────────────────────
# PostgreSQL connection URL (async)
DB_URL=postgresql+asyncpg://username:password@host:5432/database_name
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# Plenum-CAFM schema DB (optional, defaults to DB_URL if not set)
# PLENUM_DB_URL=postgresql+asyncpg://user:pass@host:5432/plenum_cafm

# ── Redis ───────────────────────────────────────────────────────────────
# Redis connection URL (optional, for caching/job queue)
REDIS_URL=redis://:password@host:6379/0
# For Azure Redis: rediss://:password@host.redis.cache.windows.net:10000/0
JOB_CONCURRENCY=5

# ── Azure Blob Storage ──────────────────────────────────────────────────
# Get from: Azure Portal → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxxxx;AccountKey=xxxxx;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=plenum-agentic-ai-attachments

# ── Fiix CMMS Platform Connector ────────────────────────────────────────
# Get from: Fiix Dashboard → Admin → API Settings
FIIX_ENABLED=true
FIIX_SUBDOMAIN=your-subdomain.onfiix.com
FIIX_APP_KEY=macmmsackpxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIIX_ACCESS_KEY=macmmsaakpxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIIX_SECRET_KEY=macmmsaskpxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIIX_TIMEOUT=20

# ── Service URLs ────────────────────────────────────────────────────────
# Internal service endpoints (for container-to-container communication)
SVC_INGESTION_URL=http://svc-ingestion:8001
SVC_QUERY_URL=http://svc-query:8002

# ── Environment & Debug ─────────────────────────────────────────────────
ENVIRONMENT=development  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
