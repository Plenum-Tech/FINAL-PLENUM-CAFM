# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/plenum_cafm

# OpenAI
OPENAI_API_KEY=sk-...
# Swap to any OpenAI model: gpt-4o-mini, gpt-4.1-mini, gpt-4.1
OPENAI_MODEL=gpt-4o-mini

# Outlook / Microsoft Graph API — client credentials (app-only, token auto-refreshed)
# Register app in Azure Entra ID, grant Mail.Read + Mail.Send + Mail.ReadWrite (Application),
# admin-consent them, then fill in the values below.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret-value
OUTLOOK_USER_EMAIL=yourname@yourdomain.com
# Background poll for approval reply emails (every N seconds). Default off — use POST /api/email/poll when testing.
APPROVAL_EMAIL_POLL_ENABLED=false
APPROVAL_EMAIL_POLL_INTERVAL_SECONDS=3600

# AIMMS
AIMMS_API_URL=http://localhost:8000
AIMMS_API_KEY=
AIMMS_URL=http://localhost:3000

# CMMS (Maximo / SAP PM)
CMMS_API_URL=
CMMS_API_KEY=
CMMS_INTEGRATION_ENABLED=false

# BMS
BMS_API_URL=
