# Database (same PostgreSQL used by all CAFM services)
DB_URL=postgresql+asyncpg://user:password@plenum-agentic-ai.postgres.database.azure.com:5432/plenum_agent

# Anthropic — UDR agent uses claude-haiku-4-5 for fast DB routing
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Safety limits
MAX_QUERY_ROWS=500
MAX_AGENT_ITERATIONS=10

# Misc
DEBUG=false
