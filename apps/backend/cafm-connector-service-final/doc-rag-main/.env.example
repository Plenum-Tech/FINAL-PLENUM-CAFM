# ==============================================================
# RAG Platform - Environment Variables
# Copy this file to `.env` and fill in your values.
# ==============================================================

# ---- App ----
APP_NAME=rag-platform
APP_ENV=development
LOG_LEVEL=INFO

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Dev mode ----
# When USE_SQLITE_DEV=true, the app uses a local SQLite DB and in-memory
# vector search — no Postgres/pgvector required. Great for quick tests.
# When false, it uses PostgreSQL + pgvector (production mode).
USE_SQLITE_DEV=false

# ---- PostgreSQL (used when USE_SQLITE_DEV=false) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_platform

# ---- SQLite path (used when USE_SQLITE_DEV=true) ----
SQLITE_PATH=./data/rag_platform.db

# ---- Anthropic (PDF extraction) ----
ANTHROPIC_API_KEY=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
CLAUDE_PDF_MODEL=claude-sonnet-4-6

# ---- OpenAI (embeddings + image vision) ----
# Leave blank to run in MOCK mode — the system will use deterministic
# hash-based pseudo-embeddings and a rule-based answerer so you can test
# the full pipeline end-to-end without an API key.
OPENAI_API_KEY=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
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
OPENAI_LLM_MODEL=gpt-4o-mini

# ---- Storage ----
UPLOAD_DIR=./data/uploads

# ---- Retrieval tuning ----
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=80
TOP_K_VECTOR=20
TOP_K_BM25=20
TOP_K_FINAL=8
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4
