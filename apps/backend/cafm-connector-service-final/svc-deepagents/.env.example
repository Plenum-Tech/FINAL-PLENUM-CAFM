# DeepAgents Orchestration Service

# OpenAI — main orchestrator uses gpt-4o-mini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional: custom OpenAI-compatible base URL (do not set if using api.openai.com directly)
# OPENAI_API_BASE=https://api.openai.com/v1
# Behind corporate VPN/proxy with SSL errors in Docker, set (local dev only):
# OPENAI_SSL_VERIFY=false
# Azure OpenAI (recommended for enterprise — avoids api.openai.com):
# CLOUD_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Tencent Cloud (OpenAI-compatible endpoint):
# CLOUD_PROVIDER=tencent
# TENCENT_OPENAI_BASE_URL=https://<tencent-openai-compatible-endpoint>/v1
# TENCENT_OPENAI_API_KEY=...
# TENCENT_OPENAI_MODEL=hunyuan-lite
# Default (auto): Azure if configured, else Tencent if configured, else OpenAI.

# Anthropic — available for future subagent use
ANTHROPIC_API_KEY=sk-ant-...

# Database (same Azure PostgreSQL used by all CAFM services)
DB_URL=postgresql+asyncpg://azure_pg_agentic_ai:Plenum_Tech1@plenum-agentic-ai.postgres.database.azure.com:5432/plenum_agent

# NOTE: UDR (user/data lookup) uses direct DB access above — no separate HTTP service needed

# WO Engine service base URL (svc-ingestion legacy alias — port 8001)
WO_ENGINE_BASE_URL=http://localhost:8001

# WO Management service base URL (svc-work-order-management — port 8007)
WO_MANAGEMENT_BASE_URL=http://localhost:8007

# Doc RAG service base URL
DOC_RAG_BASE_URL=http://localhost:8004

# Migration / AI Schema Mapper service base URL (port 8003)
MIGRATION_BASE_URL=http://localhost:8003

# Bulk ingest (Phase D3) — inline processing up to N files, then background batch
INGEST_BATCH_INLINE_THRESHOLD=3
INGEST_BATCH_CONCURRENCY=4
DEEP_AGENTS_MAX_UPLOAD_MB=50

# Phase 6 — optional object-storage connector credentials (registry stubs)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_ACCOUNT=
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=

# Service config — svc-deepagents runs on port 8008
# (port 8007 is occupied by svc-work-order-management)
PORT=8008
DEBUG=false

# HITL: set to false to disable interrupt() gates and skip Postgres checkpointer
# When true, map_fields and rollback_migration pause for human approval
HITL_ENABLED=true

# LangSmith tracing — zero-instrumentation, LangChain auto-traces when these are set
# Get your API key at https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cafm-deepagents
LANGSMITH_TRACING=false
