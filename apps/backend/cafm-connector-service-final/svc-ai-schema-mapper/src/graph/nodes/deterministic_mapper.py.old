"""Node 2: Deterministic mapper — 4-tier field mapping strategy.

Supports BOTH:
1. Hardcoded canonical fields (legacy/fallback)
2. Customer-provided JSON mapper (from json_mapper in state)

Strategies (in order):
1. Exact field name match
2. CMMS alias lookup
3. Regex pattern matching
4. Haiku constrained call (fallback)

EL-M.2: No duplicate target fields, all confidences in 0–1 range.
"""

import json
import logging
import re
from datetime import datetime
from uuid import uuid4

from anthropic import AsyncAnthropic

from ...matchers import (
    CMMS_ALIASES,
    PATTERNS,
    describe_dataset,
    get_cmms_alias,
    match_field_by_pattern,
)
from ..state import FieldMapping, MigrationState

logger = logging.getLogger(__name__)


def _normalize_field_name(field_name: str) -> str:
    """
    Normalize field name for matching.

    Handles:
    - Case insensitivity (converts to lowercase)
    - Whitespace variations (spaces, tabs, etc. → underscore)
    - Punctuation/delimiters (dashes, slashes, dots, commas → underscore)
    - Multiple consecutive delimiters → single underscore
    - Leading/trailing whitespace

    Examples:
    - "Asset Code" → "asset_code"
    - "ASSET_CODE" → "asset_code"
    - "Asset-Code" → "asset_code"
    - "Asset / Code" → "asset_code"
    - "Asset.Code" → "asset_code"
    """
    # Step 1: Lowercase
    normalized = field_name.lower().strip()

    # Step 2: Replace common delimiters with underscore
    # This regex replaces any whitespace, dash, slash, dot, comma with underscore
    normalized = re.sub(r'[\s\-_/.,;]+', '_', normalized)

    # Step 3: Remove leading/trailing underscores
    normalized = normalized.strip('_')

    return normalized


