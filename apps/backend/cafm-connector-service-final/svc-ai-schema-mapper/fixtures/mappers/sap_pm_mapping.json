  "regex_patterns": {
    "asset_id": {
      "patterns": [
        "^EQUNR$",
        "^equipment_?id$",
        "^asset_id$"
      ],
      "confidence": 0.95,
      "description": "Match SAP equipment number"
    },
    "serial_number": {
      "patterns": [
        "^SER",
        "^serial"
      ],
      "confidence": 0.90,
      "description": "Match serial fields"
    }
  },
  "custom_transformations": {
    "condition_status": {
      "type": "map",
      "values": {
        "01": "good",
        "02": "fair",
        "03": "poor",
        "A": "good",
        "I": "poor"
      },
      "description": "Map SAP status codes to standard values"
    }
  },
  "excluded_fields": [
