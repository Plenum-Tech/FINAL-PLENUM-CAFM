      "description": "Match location name fields"
    },
    "facility_address": {
      "patterns": [
        "^facility.?street",
        "^facility.?address"
      ],
      "confidence": 0.90,
      "description": "Match facility address fields"
    },
    "facility_city": {
      "patterns": [
        "^facility.?city$"
      ],
      "confidence": 0.90,
      "description": "Match facility city fields"
    },
    "facility_state": {
      "patterns": [
        "^facility.?(?:province|state)$"
      ],
      "confidence": 0.90,
      "description": "Match facility state/province fields"
    },
    "facility_postal_code": {
      "patterns": [
        "^facility.?(?:postal|zip)",
        "^postal"
      ],
      "confidence": 0.90,
      "description": "Match postal code fields"
    },
    "facility_country": {
      "patterns": [
        "^facility.?country$",
        "^country$"
      ],
      "confidence": 0.90,
      "description": "Match country fields"
    },
    "serial_number": {
      "patterns": [
        "^serial"
      ],
      "confidence": 0.9,
      "description": "Match serial number fields"
    },
    "manufacturer_name": {
      "patterns": [
        "^manufacturer",
        "^mfg"
      ],
      "confidence": 0.85,
      "description": "Match manufacturer fields"
    },
    "model_number": {
      "patterns": [
        "^model"
      ],
      "confidence": 0.85,
      "description": "Match model fields"
    }
  },
  "custom_transformations": {
    "facility_address": {
      "type": "concat",
      "fields": [
        "facility_street_address",
        "facility_city",
        "facility_state"
      ],
      "separator": ", ",
      "description": "Combine address components into full facility address"
    },
    "condition_status": {
      "type": "map",
      "values": {
        "1": "good",
        "2": "fair",
        "3": "poor",
        "G": "good",
        "F": "fair",
        "P": "poor",
        "A": "good",
        "S": "good",
        "I": "poor"
      },
      "description": "Map Maximo condition codes to standard values"
    }
  },
