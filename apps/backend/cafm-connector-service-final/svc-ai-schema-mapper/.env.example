# ── Application ───────────────────────────────────────
APP_NAME="CAFM AI Schema Mapper"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT="development"

# ── Server ─────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8003
CORS_ORIGINS="*"

# ── Database (shared PostgreSQL instance) ──────────────
DB_URL="postgresql+asyncpg://user:password@host:5432/database"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis (shared instance) ────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── OpenTelemetry ──────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"

# ── Claude API ─────────────────────────────────────────
# Generate at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_DEFAULT_MODEL="claude-haiku-4-5"

# ── OpenAI (for embeddings in semantic mapping) ────────
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"

# ── LangSmith (primary observability for this service) ─
# Generate Service Account Key at: https://smith.langchain.com/settings/api-keys
LANGSMITH_API_KEY="lsv2_sk_..."
LANGSMITH_PROJECT="cafm-ai-schema-mapper"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_TRACING=true

# ── Azure Blob ─────────────────────────────────────────
# Get from: https://portal.azure.com → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
AZURE_BLOB_CONTAINER_NAME="plenum-agentic-ai-attachments"

# ── svc-ingestion (handoff target) ──────────────────────
SVC_INGESTION_URL="http://svc-ingestion:8001"

# ── Migration limits ───────────────────────────────────
MAX_FILE_SIZE_MB=500
MAX_ROWS_PER_TABLE=5000000
MAX_UNRESOLVED_FIELDS_BEFORE_ERROR=20
