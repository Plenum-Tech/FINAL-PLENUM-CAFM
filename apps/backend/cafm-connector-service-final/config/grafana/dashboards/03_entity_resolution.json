{
  "uid": "cafm-entity-resolution",
  "title": "CAFM — Entity Resolution",
  "tags": ["cafm", "entity-resolution"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "piechart",
      "title": "Resolution Tier Distribution",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "options": {"pieType": "donut", "legend": {"displayMode": "list", "placement": "right"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (tier) (increase(cafm_entity_resolutions_total[6h]))", "legendFormat": "Tier {{tier}}"}
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tier 1 Exact Match %",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "unit": "percentunit",
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.60}, {"color": "green", "value": 0.70}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_entity_resolutions_total{tier=\"1\"}[1h])) / sum(rate(cafm_entity_resolutions_total[1h]))", "legendFormat": "tier1 %"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tier 4 (Manual) Rate",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "unit": "percentunit",
        "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.03}, {"color": "red", "value": 0.05}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_entity_resolutions_total{tier=\"4\"}[1h])) / sum(rate(cafm_entity_resolutions_total[1h]))", "legendFormat": "manual %"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "unit": "percentunit",
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.50}, {"color": "green", "value": 0.80}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "cafm_entity_resolver_cache_hit_rate", "legendFormat": "cache hit"}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unresolved (Tier 4 backlog)",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(cafm_review_queue_depth{queue_type=\"entity_resolution\"})", "legendFormat": "unresolved"}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "EL-ER.T1 Pass Rate",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 4},
      "options": {"colorMode": "value", "unit": "percentunit", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_entity_resolutions_total{tier=\"1\",eval_passed=\"true\"}[1h])) / sum(rate(cafm_entity_resolutions_total{tier=\"1\"}[1h]))", "legendFormat": "T1 pass"}]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "EL-ER.T2 Pass Rate",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 4},
      "options": {"colorMode": "value", "unit": "percentunit", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_entity_resolutions_total{tier=\"2\",eval_passed=\"true\"}[1h])) / sum(rate(cafm_entity_resolutions_total{tier=\"2\"}[1h]))", "legendFormat": "T2 pass"}]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "EL-ER.T3 Pass Rate",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 4},
      "options": {"colorMode": "value", "unit": "percentunit", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_entity_resolutions_total{tier=\"3\",eval_passed=\"true\"}[1h])) / sum(rate(cafm_entity_resolutions_total{tier=\"3\"}[1h]))", "legendFormat": "T3 pass"}]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "EL-ER.T4 Pass Rate",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 4},
      "options": {"colorMode": "value", "unit": "percentunit", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_entity_resolutions_total{tier=\"4\",eval_passed=\"true\"}[1h])) / sum(rate(cafm_entity_resolutions_total{tier=\"4\"}[1h]))", "legendFormat": "T4 pass"}]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Entity Resolutions / Hour by Tier",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (tier) (rate(cafm_entity_resolutions_total[1h])) * 3600", "legendFormat": "Tier {{tier}}"}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Fuzzy Match Score Distribution (Tier 2)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.50, sum(rate(cafm_eval_score_bucket{eval_type=\"entity_fuzzy\"}[5m])) by (le))", "legendFormat": "p50"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.90, sum(rate(cafm_eval_score_bucket{eval_type=\"entity_fuzzy\"}[5m])) by (le))", "legendFormat": "p90"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.05, sum(rate(cafm_eval_score_bucket{eval_type=\"entity_fuzzy\"}[5m])) by (le))", "legendFormat": "p5"}
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Unresolved Entity Trend",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(cafm_review_queue_depth{queue_type=\"entity_resolution\"})", "legendFormat": "pending manual review"}
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Entity Resolution Latency P95 (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le, tier) (rate(cafm_document_processing_duration_ms_bucket{operation=\"entity_resolve\"}[5m])))", "legendFormat": "p95 tier {{tier}}"}
      ]
    }
  ]
}
