{
  "uid": "cafm-claude-api-cost",
  "title": "CAFM — Claude API + Cost",
  "tags": ["cafm", "claude", "cost"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {"from": "now-24h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(cafm_claude_api_calls_total, model)",
        "current": {"text": "All", "value": "$__all"},
        "multi": true,
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Claude API Calls (24h)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(increase(cafm_claude_api_calls_total[24h]))", "legendFormat": "calls"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Tokens Used (24h)",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(increase(cafm_claude_tokens_total[24h]))", "legendFormat": "tokens"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cost Today (USD)",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["sum"]},
        "unit": "currencyUSD",
        "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(increase(cafm_claude_cost_usd_total[24h]))", "legendFormat": "USD"}]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Budget Used %",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "minVizValue": 0,
        "maxVizValue": 100,
        "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}
      },
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "cafm_claude_budget_used_pct * 100", "legendFormat": "budget %"}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "unit": "percentunit",
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.50}, {"color": "green", "value": 0.80}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_claude_tokens_total{token_type=\"cache_read\"}[1h])) / sum(rate(cafm_claude_tokens_total[1h]))", "legendFormat": "cache hit rate"}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "API Calls / Hour",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_claude_api_calls_total[1h])) * 3600", "legendFormat": "calls/hr"}]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Claude API Calls / Hour by Model",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (model) (rate(cafm_claude_api_calls_total[1h])) * 3600", "legendFormat": "{{model}}"}
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Claude API Latency P95 (ms) by Model",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le, model) (rate(cafm_claude_latency_ms_bucket[5m])))", "legendFormat": "p95 {{model}}"}
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Token Usage / Hour by Type",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (token_type) (rate(cafm_claude_tokens_total[1h])) * 3600", "legendFormat": "{{token_type}}"}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Cost (USD) Burn Rate / Hour",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (model) (rate(cafm_claude_cost_usd_total[1h])) * 3600", "legendFormat": "{{model}}"}
      ]
    },
    {
      "id": 30,
      "type": "barchart",
      "title": "Cost Breakdown by Agent (Last 24h)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "options": {"barWidth": 0.7, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (agent_id) (increase(cafm_claude_cost_usd_total[24h]))", "legendFormat": "{{agent_id}}"}
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Cumulative Cost (USD) — 7 Day",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(cafm_claude_cost_usd_total)", "legendFormat": "cumulative USD"}
      ]
    }
  ]
}
