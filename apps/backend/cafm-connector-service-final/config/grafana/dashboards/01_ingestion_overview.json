{
  "uid": "cafm-ingestion-overview",
  "title": "CAFM — Ingestion Overview",
  "tags": ["cafm", "ingestion"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(up, job)",
        "current": {"text": "All", "value": "$__all"},
        "multi": true,
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Documents Ingested (Total)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(cafm_documents_ingested_total)", "legendFormat": "Total"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Docs Ingested / Hour",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_documents_ingested_total[1h])) * 3600", "legendFormat": "docs/hr"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Review Queue Depth",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "cafm_review_queue_depth", "legendFormat": "depth"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Held for Review Rate",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "unit": "percentunit",
        "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.10}, {"color": "red", "value": 0.20}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_review_queue_enqueued_total[1h])) / sum(rate(cafm_documents_ingested_total[1h]))", "legendFormat": "held rate"}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg EL-2.3 eval_score",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.60}, {"color": "green", "value": 0.85}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.50, sum(rate(cafm_eval_score_bucket[1h])) by (le))", "legendFormat": "p50 eval_score"}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active ARQ Workers",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(up{job=~\"cafm.*\"})", "legendFormat": "workers up"}]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Documents Ingested / Hour by Agent",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (agent_id) (rate(cafm_documents_ingested_total[1h])) * 3600", "legendFormat": "{{agent_id}}"}
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Ingestion Duration P95 (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le, agent_id) (rate(cafm_document_processing_duration_ms_bucket[5m])))", "legendFormat": "p95 {{agent_id}}"}
      ]
    },
    {
      "id": 20,
      "type": "histogram",
      "title": "EL-2.3 eval_score Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "options": {"fillOpacity": 80, "bucketOffset": 0},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_eval_score_bucket[5m])) by (le)", "legendFormat": "{{le}}", "format": "heatmap"}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Review Queue Events / Hour",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (reason) (rate(cafm_review_queue_enqueued_total[1h])) * 3600", "legendFormat": "{{reason}}"}
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Entity Resolutions / Hour by Tier",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (tier) (rate(cafm_entity_resolutions_total[1h])) * 3600", "legendFormat": "tier {{tier}}"}
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "HTTP Request Rate — svc-ingestion",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (http_route) (rate(http_server_duration_milliseconds_count{job=\"cafm-ingestion-service\"}[5m]))", "legendFormat": "{{http_route}}"}
      ]
    }
  ]
}
