{
  "uid": "cafm-layer5-layer6",
  "title": "CAFM — Layer 5 + Layer 6 (Determinism)",
  "tags": ["cafm", "layer5", "layer6", "agents"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "agent",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(cafm_documents_ingested_total, agent_id)",
        "current": {"text": "All", "value": "$__all"},
        "multi": true,
        "includeAll": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "EL-5.BOUND Pass Rate",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "options": {
        "colorMode": "background",
        "unit": "percentunit",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.90}, {"color": "green", "value": 0.99}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_documents_ingested_total{eval_layer=\"el5_bound\",result=\"pass\"}[1h])) / sum(rate(cafm_documents_ingested_total{eval_layer=\"el5_bound\"}[1h]))", "legendFormat": "bound pass"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "EL-5.AGG Valid Runs / Total",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "options": {"colorMode": "value", "unit": "percentunit", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_documents_ingested_total{eval_layer=\"el5_agg\",result=\"valid\"}[1h])) / sum(rate(cafm_documents_ingested_total{eval_layer=\"el5_agg\"}[1h]))", "legendFormat": "agg valid"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg runs_agreed (N=3 votes)",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 2}, {"color": "green", "value": 2.5}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg(cafm_eval_score{metric_type=\"runs_agreed\"})", "legendFormat": "avg runs agreed"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Hard Rules Fired (24h)",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(increase(cafm_documents_ingested_total{eval_layer=\"el5_constrain\",result=\"hard_rule_fired\"}[24h]))", "legendFormat": "hard rules"}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "EL-6.BOUND Pass Rate",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "options": {
        "colorMode": "background",
        "unit": "percentunit",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.90}, {"color": "green", "value": 0.99}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_documents_ingested_total{eval_layer=\"el6_bound\",result=\"pass\"}[1h])) / sum(rate(cafm_documents_ingested_total{eval_layer=\"el6_bound\"}[1h]))", "legendFormat": "l6 bound pass"}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "L6 Confidence Gate Pass Rate",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "options": {
        "colorMode": "background",
        "unit": "percentunit",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.80}, {"color": "green", "value": 0.95}]}
      },
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_documents_ingested_total{eval_layer=\"el6_constrain\",result=\"gate_passed\"}[1h])) / sum(rate(cafm_documents_ingested_total{eval_layer=\"el6_constrain\"}[1h]))", "legendFormat": "gate pass"}]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Agent Run Time P95 (ms) by Agent",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le, agent_id) (rate(cafm_document_processing_duration_ms_bucket{operation=\"agent_run\"}[5m])))", "legendFormat": "p95 {{agent_id}}"}
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "EL-5.BOUND Pass/Fail Rate by Agent",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (agent_id) (rate(cafm_documents_ingested_total{eval_layer=\"el5_bound\",result=\"pass\"}[5m]))", "legendFormat": "pass {{agent_id}}"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (agent_id) (rate(cafm_documents_ingested_total{eval_layer=\"el5_bound\",result=\"fail\"}[5m]))", "legendFormat": "fail {{agent_id}}"}
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Votes Agreed Distribution Over Time",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (runs_agreed) (rate(cafm_documents_ingested_total{eval_layer=\"el5_vote\"}[5m]))", "legendFormat": "{{runs_agreed}} agreed"}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Hard Rules Fired by Agent",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (agent_id, rule_id) (rate(cafm_documents_ingested_total{eval_layer=\"el5_constrain\",result=\"hard_rule_fired\"}[5m])) * 3600", "legendFormat": "{{agent_id}} / {{rule_id}}"}
      ]
    },
    {
      "id": 30,
      "type": "piechart",
      "title": "Layer 6 Action Distribution",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 20},
      "options": {"pieType": "pie", "legend": {"displayMode": "list", "placement": "right"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (action) (increase(cafm_documents_ingested_total{eval_layer=\"el6_constrain\"}[24h]))", "legendFormat": "{{action}}"}
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "EL-6.CONSTRAIN Gate Results Over Time",
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 20},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (action, result) (rate(cafm_documents_ingested_total{eval_layer=\"el6_constrain\"}[5m]))", "legendFormat": "{{action}} / {{result}}"}
      ]
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Human Review Required — Flagged by Layer",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (agent_id) (rate(cafm_documents_ingested_total{eval_layer=\"el5_constrain\",human_review=\"true\"}[5m])) * 3600", "legendFormat": "L5 {{agent_id}}"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(cafm_documents_ingested_total{eval_layer=\"el6_constrain\",human_review=\"true\"}[5m])) * 3600", "legendFormat": "L6 orchestrator"}
      ]
    }
  ]
}
